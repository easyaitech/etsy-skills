# 复制成 .env 填好。.env 已在 .gitignore,不会进仓库。
OPENROUTER_API_KEY=sk-or-xxxxxxxx

# 你的 workspace 根目录(含 BRAND.md / SHOP.md / COMMERCE_PLATFORM.md)。
# 不填也能跑,只是草稿不带你的品牌语调/政策。
ETSY_WORKSPACE=/绝对路径/到你的/workspace

# OpenRouter 上的模型 id。客服回复建议用强一点的;例:
#   anthropic/claude-sonnet-4.5   openai/gpt-4o   google/gemini-2.5-pro   openai/gpt-4o-mini(便宜默认)
MODEL=openai/gpt-4o-mini

# 可选:客服 SOP 文件;默认用本仓 orders-customers/references/order-handling.md
# SOP_PATH=

# 可选:端口,默认 8787(扩展 BRAIN_URL 也是这个)
# PORT=8787
