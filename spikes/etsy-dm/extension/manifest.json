{
  "manifest_version": 3,
  "name": "Etsy DM 助手 (v0.1 spike)",
  "version": "0.1.0",
  "description": "命脉验证:能否在 HubStudio 里跑、读 Etsy 私信、把草稿填进回复框(不发送)。",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.etsy.com/*",
    "http://127.0.0.1/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://www.etsy.com/your/conversations*",
        "https://www.etsy.com/messages/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
