#!/usr/bin/env bash
# One-command runner for trend-radar.
set -uo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
KEYWORD="Chinese"
GEO="US"
RUN_DATE="$(date +%F)"
WORKSPACE="${ETSY_WORKSPACE:-}"
HEADED_GOOGLE="false"
HEADED_EXOLYT="false"
SKIP_GOOGLE="false"
SKIP_EXOLYT="false"

usage() {
  cat <<EOF
trend-radar-run — run the Chinese/US trend radar once

Usage:
  scripts/trend-radar-run [--workspace PATH] [--date YYYY-MM-DD]
                          [--headed-google] [--headed-exolyt]
                          [--skip-google] [--skip-exolyt]

Environment:
  ETSY_WORKSPACE   Workspace root. Optional if --workspace is passed or .etsy-workspace can be resolved.
  SERPAPI_KEY      Optional Google Trends fallback key.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --workspace)
      WORKSPACE="$2"
      shift 2
      ;;
    --workspace=*)
      WORKSPACE="${1#*=}"
      shift
      ;;
    --date)
      RUN_DATE="$2"
      shift 2
      ;;
    --date=*)
      RUN_DATE="${1#*=}"
      shift
      ;;
    --headed-google)
      HEADED_GOOGLE="true"
      shift
      ;;
    --headed-exolyt)
      HEADED_EXOLYT="true"
      shift
      ;;
    --skip-google)
      SKIP_GOOGLE="true"
      shift
      ;;
    --skip-exolyt)
      SKIP_EXOLYT="true"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ "$KEYWORD" != "Chinese" || "$GEO" != "US" ]]; then
  echo "trend-radar v0 only allows keyword=Chinese and geo=US" >&2
  exit 2
fi

if [[ -z "$WORKSPACE" ]]; then
  WORKSPACE="$(bash "$ROOT/scripts/etsy-stack" workspace 2>/dev/null)"
fi
if [[ -z "$WORKSPACE" || ! -d "$WORKSPACE" ]]; then
  echo "ETSY_WORKSPACE is required and must point to an existing directory." >&2
  exit 2
fi
WORKSPACE="$(cd "$WORKSPACE" && pwd)"

RUN_ID="$RUN_DATE"
suffix=1
while [[ -e "$WORKSPACE/trend-radar/reports/$RUN_ID.md" || -e "$WORKSPACE/trend-radar/data/$RUN_ID.json" ]]; do
  suffix=$((suffix + 1))
  RUN_ID="$(printf "%s-%02d" "$RUN_DATE" "$suffix")"
done

RAW_ROOT="$WORKSPACE/trend-radar/raw"
GOOGLE_DIR="$RAW_ROOT/google-trends/$RUN_ID"
EXOLYT_DIR="$RAW_ROOT/exolyt/$RUN_ID"
REPORT_PATH="$WORKSPACE/trend-radar/reports/$RUN_ID.md"
DATA_PATH="$WORKSPACE/trend-radar/data/$RUN_ID.json"

mkdir -p "$GOOGLE_DIR" "$EXOLYT_DIR" "$WORKSPACE/trend-radar/reports" "$WORKSPACE/trend-radar/data" "$WORKSPACE/.cache/trend-radar"

GOOGLE_FAILED="false"
GOOGLE_NEEDS_FALLBACK="false"
if [[ "$SKIP_GOOGLE" != "true" ]]; then
  if ! node "$ROOT/trend-radar/scripts/browser-google-trends.mjs" \
    --keyword "$KEYWORD" \
    --geo "$GEO" \
    --out-dir "$GOOGLE_DIR" \
    --profile-dir "$WORKSPACE/.cache/trend-radar/google-profile" \
    --headed "$HEADED_GOOGLE"; then
    GOOGLE_FAILED="true"
  fi
  if [[ -f "$GOOGLE_DIR/google-trends-summary.json" ]]; then
    if ! python3 - "$GOOGLE_DIR/google-trends-summary.json" <<'PY'
import json, sys
with open(sys.argv[1], encoding="utf-8") as f:
    payload = json.load(f)
results = payload.get("results", [])
normalized = sum(len(r.get("normalized") or []) for r in results)
failures = [failure for r in results for failure in (r.get("failures") or [])]
hard_failures = {"google_429_too_many_requests", "google_page_error", "no_related_response_captured"}
if normalized == 0 or any(f in hard_failures for f in failures):
    raise SystemExit(1)
PY
    then
      GOOGLE_NEEDS_FALLBACK="true"
    fi
  else
    GOOGLE_NEEDS_FALLBACK="true"
  fi
else
  GOOGLE_FAILED="true"
fi

if [[ "$SKIP_GOOGLE" != "true" && ( "$GOOGLE_FAILED" == "true" || "$GOOGLE_NEEDS_FALLBACK" == "true" ) && -n "${SERPAPI_KEY:-}" ]]; then
  mkdir -p "$GOOGLE_DIR/serpapi"
  python3 "$ROOT/trend-radar/scripts/fetch-serpapi-google-trends.py" \
    --keyword "$KEYWORD" --geo "$GEO" --date "now 7-d" --data-type RELATED_QUERIES \
    --out "$GOOGLE_DIR/serpapi/7d-related-queries.json" || true
  python3 "$ROOT/trend-radar/scripts/fetch-serpapi-google-trends.py" \
    --keyword "$KEYWORD" --geo "$GEO" --date "now 7-d" --data-type RELATED_TOPICS \
    --out "$GOOGLE_DIR/serpapi/7d-related-topics.json" || true
  python3 "$ROOT/trend-radar/scripts/fetch-serpapi-google-trends.py" \
    --keyword "$KEYWORD" --geo "$GEO" --date "today 1-m" --data-type RELATED_QUERIES \
    --out "$GOOGLE_DIR/serpapi/30d-related-queries.json" || true
  python3 "$ROOT/trend-radar/scripts/fetch-serpapi-google-trends.py" \
    --keyword "$KEYWORD" --geo "$GEO" --date "today 1-m" --data-type RELATED_TOPICS \
    --out "$GOOGLE_DIR/serpapi/30d-related-topics.json" || true
fi

if [[ "$SKIP_EXOLYT" != "true" ]]; then
  node "$ROOT/trend-radar/scripts/browser-exolyt.mjs" \
    --keyword "$KEYWORD" \
    --out-dir "$EXOLYT_DIR" \
    --profile-dir "$WORKSPACE/.cache/trend-radar/exolyt-profile" \
    --headed "$HEADED_EXOLYT" || true
fi

python3 "$ROOT/trend-radar/scripts/aggregate-trend-radar.py" \
  --run-id "$RUN_ID" \
  --workspace "$WORKSPACE" \
  --google-dir "$GOOGLE_DIR" \
  --exolyt-dir "$EXOLYT_DIR" \
  --out-report "$REPORT_PATH" \
  --out-json "$DATA_PATH"
