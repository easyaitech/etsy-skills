#!/usr/bin/env bash
# ecommerce-stack / etsy-stack — 管理电商 skill bundle 的 CLI
set -uo pipefail

CMD_NAME="$(basename "$0")"
INSTALL_DIR="${ECOMMERCE_SKILLS_HOME:-${ETSY_SKILLS_HOME:-$HOME/.local/share/etsy-skills}}"
CACHE_DIR="${ECOMMERCE_STACK_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/ecommerce-skills}"
HERMES_SKILLS_DIR="${HERMES_SKILLS_DIR:-${HERMES_HOME:-$HOME/.hermes}/skills}"
PINTEREST_AUTOPIN_REPO="${PINTEREST_AUTOPIN_REPO:-}"
PINTEREST_AUTOPIN_DIR="${PINTEREST_AUTOPIN_HOME:-$HOME/code/etsy-skills/tools/Pinterest-autopin}"
PINTEREST_AUTOPIN_MIN_VERSION="1.4.0"
AI_CLEANER_REPO="${AI_CLEANER_REPO:-https://github.com/wiltodelta/remove-ai-watermarks.git}"

usage() {
  cat <<EOF
$CMD_NAME — 电商 skill bundle 管理工具（兼容旧 etsy-stack 名称）

用法：
  $CMD_NAME version            当前安装版本
  $CMD_NAME check              立即检查更新（绕过 24h 缓存）
  $CMD_NAME update             拉最新版本并刷新软链
  $CMD_NAME list               列出 manifest 中的 skill 及链接状态
  $CMD_NAME doctor [--quarantine]  体检：非托管 skill 目录 + 校验工作区 skill-prefs
  $CMD_NAME pinterest-tool     查看 / 更新 Pinterest-autopin 发布工具
  $CMD_NAME ai-cleaner         查看 / 安装 AI 发布图清理工具
  $CMD_NAME where              打印源码安装目录
  $CMD_NAME workspace          解析当前电商工作区根目录
  $CMD_NAME init [DIR]         在 DIR（默认 cwd）创建 .ecommerce-workspace 标记
  $CMD_NAME help               查看本帮助
EOF
}

pinterest_tool_version() {
  [[ -f "$PINTEREST_AUTOPIN_DIR/package.json" ]] || return 1
  PINTEREST_AUTOPIN_DIR="$PINTEREST_AUTOPIN_DIR" python3 - <<'PY'
import json, os
path = os.path.join(os.environ["PINTEREST_AUTOPIN_DIR"], "package.json")
with open(path, encoding="utf-8") as f:
    print(json.load(f).get("version", "unknown"))
PY
}

version_at_least() {
  python3 - "$1" "$2" <<'PY'
import sys

def parts(v):
    out = []
    for item in v.split("."):
        digits = "".join(ch for ch in item if ch.isdigit())
        out.append(int(digits or 0))
    return (out + [0, 0, 0])[:3]

sys.exit(0 if parts(sys.argv[1]) >= parts(sys.argv[2]) else 1)
PY
}

pinterest_tool_status() {
  echo "Pinterest-autopin 工具路径：$PINTEREST_AUTOPIN_DIR"
  if [[ ! -d "$PINTEREST_AUTOPIN_DIR" ]]; then
    echo "状态：未安装"
    echo "安装 / 更新：$CMD_NAME pinterest-tool update"
    return 1
  fi

  local version
  version="$(pinterest_tool_version 2>/dev/null || echo unknown)"
  echo "版本：$version"
  if [[ "$version" != "unknown" ]] && version_at_least "$version" "$PINTEREST_AUTOPIN_MIN_VERSION"; then
    echo "轮播发布：可用（需要 Pinterest 企业账号，工具会走 Ads Manager Pin builder）"
  else
    echo "轮播发布：不可用（需要 Pinterest-autopin >= $PINTEREST_AUTOPIN_MIN_VERSION）"
    echo "升级：$CMD_NAME pinterest-tool update"
    return 1
  fi

  if git -C "$PINTEREST_AUTOPIN_DIR" rev-parse --git-dir >/dev/null 2>&1; then
    local branch commit
    branch="$(git -C "$PINTEREST_AUTOPIN_DIR" branch --show-current 2>/dev/null || echo detached)"
    commit="$(git -C "$PINTEREST_AUTOPIN_DIR" rev-parse --short HEAD 2>/dev/null || echo unknown)"
    echo "Git：$branch@$commit"
  fi
}

pinterest_tool_update() {
  mkdir -p "$(dirname "$PINTEREST_AUTOPIN_DIR")"

  if [[ -e "$PINTEREST_AUTOPIN_DIR" && ! -d "$PINTEREST_AUTOPIN_DIR/.git" ]]; then
    echo "❌ $PINTEREST_AUTOPIN_DIR 已存在但不是 git 仓库，无法自动更新" >&2
    return 1
  fi

  if [[ ! -d "$PINTEREST_AUTOPIN_DIR/.git" ]]; then
    if [[ -z "$PINTEREST_AUTOPIN_REPO" ]]; then
      echo "❌ 未配置 Pinterest-autopin 工具仓库。请先设置 PINTEREST_AUTOPIN_REPO，或使用已有工具目录：$PINTEREST_AUTOPIN_DIR" >&2
      return 1
    fi
    echo "Clone Pinterest-autopin → $PINTEREST_AUTOPIN_DIR"
    git clone --quiet "$PINTEREST_AUTOPIN_REPO" "$PINTEREST_AUTOPIN_DIR" || return 1
  fi

  local remote_url
  remote_url="$(git -C "$PINTEREST_AUTOPIN_DIR" remote get-url origin 2>/dev/null || true)"
  if [[ -n "$PINTEREST_AUTOPIN_REPO" ]]; then
    git -C "$PINTEREST_AUTOPIN_DIR" remote set-url origin "$PINTEREST_AUTOPIN_REPO" || return 1
    remote_url="$PINTEREST_AUTOPIN_REPO"
  elif [[ "$remote_url" == *"easyaitech/Pinterest-autopin"* ]]; then
    echo "❌ Pinterest-autopin 工具仍指向旧仓库：$remote_url" >&2
    echo "   请先核实真实工具来源，并通过 PINTEREST_AUTOPIN_REPO 显式指定后再更新。" >&2
    return 1
  fi

  if [[ -n "$(git -C "$PINTEREST_AUTOPIN_DIR" status --porcelain)" ]]; then
    echo "❌ Pinterest-autopin 工具有本地未提交改动，先处理后再更新：$PINTEREST_AUTOPIN_DIR" >&2
    return 1
  fi

  echo "更新 Pinterest-autopin 工具源码"
  git -C "$PINTEREST_AUTOPIN_DIR" fetch --quiet --prune origin || return 1
  git -C "$PINTEREST_AUTOPIN_DIR" checkout --quiet main || return 1
  git -C "$PINTEREST_AUTOPIN_DIR" merge --ff-only --quiet origin/main || return 1

  if command -v npm >/dev/null; then
    echo "安装 / 刷新 npm 依赖"
    npm --prefix "$PINTEREST_AUTOPIN_DIR" install --silent || return 1
  else
    echo "⚠️  未找到 npm；工具源码已更新，但依赖还没安装" >&2
  fi

  pinterest_tool_status
}

ai_cleaner_status() {
  if ! command -v remove-ai-watermarks >/dev/null 2>&1; then
    echo "AI 发布图清理工具：未安装"
    echo "安装 / 更新：$CMD_NAME ai-cleaner update"
    return 1
  fi

  echo "AI 发布图清理工具：$(command -v remove-ai-watermarks)"
  remove-ai-watermarks --version 2>/dev/null || true
  echo "默认用途：只在最终 listing 图片和社媒待发布图片的发布副本上清 AI metadata / AI visible watermark"
}

ai_cleaner_update() {
  if command -v uv >/dev/null 2>&1; then
    if command -v remove-ai-watermarks >/dev/null 2>&1; then
      uv tool upgrade remove-ai-watermarks || return 1
    else
      uv tool install "git+$AI_CLEANER_REPO" || return 1
    fi
  elif command -v pipx >/dev/null 2>&1; then
    if command -v remove-ai-watermarks >/dev/null 2>&1; then
      pipx upgrade remove-ai-watermarks || return 1
    else
      pipx install "git+$AI_CLEANER_REPO" || return 1
    fi
  else
    echo "❌ 未找到 uv 或 pipx，无法安装 remove-ai-watermarks" >&2
    echo "   建议先安装 uv：https://docs.astral.sh/uv/" >&2
    return 1
  fi

  ai_cleaner_status
}

# 解析电商工作区根目录。顺序：
#   1. $ECOMMERCE_WORKSPACE 环境变量（指向不存在目录视为错误）
#   2. 兼容旧 $ETSY_WORKSPACE 环境变量（指向不存在目录视为错误）
#   3. 从 cwd 向上找 .ecommerce-workspace 标记文件
#   4. 兼容旧 .etsy-workspace 标记文件
# 成功 → echo 路径，return 0
# 工作区环境变量设了但目录不存在 → return 2
# 完全找不到 → return 1
# 不打印任何内容；调用方决定怎么报错
resolve_workspace() {
  local workspace_env
  workspace_env="${ECOMMERCE_WORKSPACE:-${ETSY_WORKSPACE:-}}"
  if [[ -n "$workspace_env" ]]; then
    if [[ -d "$workspace_env" ]]; then
      ( cd "$workspace_env" && pwd )
      return 0
    else
      return 2
    fi
  fi

  local dir
  dir="$(pwd)"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/.ecommerce-workspace" || -f "$dir/.etsy-workspace" ]]; then
      echo "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done

  return 1
}

require_install() {
  git -C "$INSTALL_DIR" rev-parse --git-dir >/dev/null 2>&1 || {
    echo "❌ 找不到电商 skill bundle 源码（${INSTALL_DIR}）" >&2
    echo "   请重新跑安装脚本：" >&2
    echo "   curl -fsSL https://raw.githubusercontent.com/easyaitech/etsy-skills/main/install.sh | bash" >&2
    exit 1
  }
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  version|-v|--version)
    require_install
    git -C "$INSTALL_DIR" describe --tags --always 2>/dev/null || echo "unknown"
    ;;

  check)
    require_install
    rm -f "$CACHE_DIR/last-check" "$CACHE_DIR"/latest-*
    out=$(bash "$INSTALL_DIR/scripts/check-update.sh")
    if [[ -z "$out" ]]; then
      current=$(git -C "$INSTALL_DIR" describe --tags --always 2>/dev/null || echo "unknown")
      echo "✓ 已是最新（当前：${current}）"
    else
      echo "$out"
    fi
    ;;

  update|upgrade)
    require_install
    exec bash "$INSTALL_DIR/install.sh"
    ;;

  pinterest-tool|pinterest-autopin-tool)
    subcmd="${1:-status}"
    case "$subcmd" in
      status|"")
        pinterest_tool_status
        ;;
      update|upgrade|install)
        pinterest_tool_update
        ;;
      path)
        echo "$PINTEREST_AUTOPIN_DIR"
        ;;
      *)
        echo "未知 pinterest-tool 子命令：$subcmd" >&2
        echo "可用：status / update / path" >&2
        exit 1
        ;;
    esac
    ;;

  ai-cleaner|image-cleaner)
    subcmd="${1:-status}"
    case "$subcmd" in
      status|"")
        ai_cleaner_status
        ;;
      update|upgrade|install)
        ai_cleaner_update
        ;;
      path)
        command -v remove-ai-watermarks || exit 1
        ;;
      *)
        echo "未知 ai-cleaner 子命令：$subcmd" >&2
        echo "可用：status / update / path" >&2
        exit 1
        ;;
    esac
    ;;

  list|ls)
    require_install
    INSTALL_DIR="$INSTALL_DIR" HERMES_SKILLS_DIR="$HERMES_SKILLS_DIR" CMD_NAME="$CMD_NAME" python3 -c '
import json, os
install_dir = os.environ["INSTALL_DIR"]
hermes_dir = os.environ["HERMES_SKILLS_DIR"]
cmd_name = os.environ["CMD_NAME"]
with open(os.path.join(install_dir, "etsy-stack.json")) as f:
    manifest = json.load(f)
for skill in manifest["skills"]:
    link = os.path.join(hermes_dir, skill)
    if os.path.islink(link):
        status = "✓" if os.path.exists(link) else "⚠️ 链接断了"
    elif os.path.exists(link):
        status = "⚠️ 非软链"
    else:
        status = "✗ 未安装"
    print(f"  {status}  {skill}")
managed = set(manifest["skills"]) | {"shared"}
extras = []
if os.path.isdir(hermes_dir):
    for name in sorted(os.listdir(hermes_dir)):
        if name in managed or name.startswith("."):
            continue
        extras.append(name)
if extras:
    print("")
    print("  非 stack 管理的条目（manifest 之外，可能是 agent 自建或历史遗留）：")
    for name in extras:
        p = os.path.join(hermes_dir, name)
        kind = "软链" if os.path.islink(p) else ("目录" if os.path.isdir(p) else "文件")
        print(f"  ⚠️ 非托管  {name}  [{kind}]")
    print(f"  → 用 `{cmd_name} doctor --quarantine` 隔离它们")
'
    ;;

  doctor)
    require_install
    quarantine=0
    [[ "${1:-}" == "--quarantine" ]] && quarantine=1
    ws="$(resolve_workspace 2>/dev/null)" || ws=""
    INSTALL_DIR="$INSTALL_DIR" HERMES_SKILLS_DIR="$HERMES_SKILLS_DIR" CMD_NAME="$CMD_NAME" \
      WORKSPACE="$ws" QUARANTINE="$quarantine" python3 - <<'PY'
import json, os, shutil, time

install_dir = os.environ["INSTALL_DIR"]
hermes_dir = os.environ["HERMES_SKILLS_DIR"]
cmd_name = os.environ["CMD_NAME"]
workspace = os.environ.get("WORKSPACE", "")
quarantine = os.environ.get("QUARANTINE") == "1"

with open(os.path.join(install_dir, "etsy-stack.json")) as f:
    manifest = json.load(f)
managed = set(manifest["skills"]) | {"shared"}

# 1) 技能目录：找 manifest 之外的非托管条目（agent 自建写入会落在这里）
extras = []
if os.path.isdir(hermes_dir):
    for name in sorted(os.listdir(hermes_dir)):
        if name in managed or name.startswith("."):
            continue
        extras.append(name)

print(f"技能目录：{hermes_dir}")
if not extras:
    print("  ✓ 没有非托管条目")
else:
    print(f"  ⚠️ 发现 {len(extras)} 个非 stack 管理的条目（manifest 之外）：")
    for name in extras:
        p = os.path.join(hermes_dir, name)
        kind = "软链" if os.path.islink(p) else ("目录" if os.path.isdir(p) else "文件")
        print(f"     • {name}  [{kind}]")
    if quarantine:
        ts = time.strftime("%Y%m%d-%H%M%S")
        qdir = os.path.join(hermes_dir, ".quarantine", ts)
        os.makedirs(qdir, exist_ok=True)
        for name in extras:
            shutil.move(os.path.join(hermes_dir, name), os.path.join(qdir, name))
        print(f"  ✓ 已隔离到 {qdir}（未删除，可人工复核）")
    else:
        print(f"  → 确认要清理就跑：{cmd_name} doctor --quarantine")

# 2) 工作区 skill-prefs：校验目标 skill 是否还在 manifest
print("")
valid = set(manifest["skills"])
if not workspace:
    print("skill-prefs：未解析到工作区（在工作区目录内运行 doctor 可校验）")
else:
    prefs_dir = os.path.join(workspace, "skill-prefs")
    if not os.path.isdir(prefs_dir):
        print(f"skill-prefs：{prefs_dir}（无，跳过）")
    else:
        files = [f for f in sorted(os.listdir(prefs_dir)) if f.endswith(".md") and f != "README.md"]
        print(f"skill-prefs：{prefs_dir}")
        if not files:
            print("  （空）")
        for f in files:
            skill = f[:-3]
            mark = "✓" if skill in valid else "⚠️ 目标 skill 不在 manifest"
            print(f"  {mark}  {f}")
PY
    ;;

  where)
    echo "$INSTALL_DIR"
    ;;

  workspace|ws)
    out="$(resolve_workspace)"
    rc=$?
    case $rc in
      0)
        echo "$out"
        exit 0
        ;;
      2)
        if [[ -n "${ECOMMERCE_WORKSPACE:-}" ]]; then
          echo "❌ \$ECOMMERCE_WORKSPACE 指向的目录不存在：${ECOMMERCE_WORKSPACE}" >&2
        else
          echo "❌ \$ETSY_WORKSPACE 指向的目录不存在：${ETSY_WORKSPACE:-}" >&2
        fi
        echo "   请把它指向实际存在的工作区根目录。" >&2
        exit 1
        ;;
      *)
        cat >&2 <<'EOF'
❌ 找不到电商工作区。

按以下任一方式声明：

  1. 设置环境变量（推荐写进 shell 配置）：
       export ECOMMERCE_WORKSPACE=/path/to/your/ecommerce-workspace

  2. 在工作区根目录跑一次 `ecommerce-stack init`，会写一个 .ecommerce-workspace 标记文件，
     之后从工作区子目录调用本命令会自动向上找到根。

不要让 skill 把文件写到当前目录或 $HOME 下——Hermes profile 的 $HOME 不是
系统用户 HOME，会落到 profile sandbox 里。
EOF
        exit 1
        ;;
    esac
    ;;

  init)
    target="${1:-$(pwd)}"
    if [[ ! -d "$target" ]]; then
      echo "❌ 目录不存在：$target" >&2
      exit 1
    fi
    target="$( cd "$target" && pwd )"
    marker="$target/.ecommerce-workspace"
    legacy_marker="$target/.etsy-workspace"
    if [[ -f "$marker" || -f "$legacy_marker" ]]; then
      echo "✓ 已是电商工作区：$target"
      if [[ -f "$marker" ]]; then
        echo "  （$marker 已存在，未覆盖）"
      else
        echo "  （兼容旧标记 $legacy_marker，未覆盖）"
      fi
      exit 0
    fi
    cat > "$marker" <<EOF
# E-commerce workspace marker
# 由 $CMD_NAME init 创建。skill 会向上找这个文件来定位工作区根目录。
name=$(basename "$target")
created=$(date +%Y-%m-%d)
EOF
    echo "✓ 已初始化电商工作区：$target"
    echo ""
    echo "建议把下面这行加到 shell 配置（~/.zshrc 或 ~/.bashrc），跨目录也能定位："
    echo ""
    echo "  export ECOMMERCE_WORKSPACE=\"$target\""
    echo ""
    if [[ -d "$target/.git" ]] || git -C "$target" rev-parse --git-dir >/dev/null 2>&1; then
      echo "工作区是 git 仓库——记得把以下两行加进 .gitignore："
      echo "  .cache/             # Pinterest-autopin runtime 等临时数据"
      echo "  # .ecommerce-workspace   # 标记文件本身建议提交，便于团队成员从 cwd 自动定位"
      echo ""
    fi
    mkdir -p "$target/skill-prefs"
    if [[ ! -f "$target/skill-prefs/README.md" ]]; then
      cat > "$target/skill-prefs/README.md" <<'PREFS'
# 客户偏好覆盖（skill-prefs）

每个文件 `<skill-name>.md` 覆盖对应 skill 的工作流 / 风格旋钮，升级不冲突。
完整契约见 stack 的 `shared/skill-prefs.md`。

- 品牌语气 / 店铺事实 / 平台规则 → 走 shop-foundation 写进 BRAND.md / SHOP.md / COMMERCE_PLATFORM.md，不是这里。
- 安全 / 合规 / QA / 写入确认 → 不可被覆盖。
PREFS
      echo "✓ 已创建 skill-prefs/（客户偏好覆盖层，见 shared/skill-prefs.md）"
    fi
    echo "下一步：用 shop-foundation 建 BRAND.md / SHOP.md / COMMERCE_PLATFORM.md"
    ;;

  help|-h|--help|"")
    usage
    ;;

  *)
    echo "未知命令：$cmd" >&2
    echo "" >&2
    usage >&2
    exit 1
    ;;
esac
