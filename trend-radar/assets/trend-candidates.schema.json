{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Trend Radar Candidates",
  "type": "object",
  "required": ["run_date", "keyword", "geo", "windows", "sources_used", "source_failures", "candidates"],
  "properties": {
    "run_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}(-\\d{2})?$"
    },
    "keyword": {
      "const": "Chinese"
    },
    "geo": {
      "const": "US"
    },
    "windows": {
      "type": "array",
      "items": {
        "enum": ["7d", "30d"]
      },
      "minItems": 1
    },
    "sources_used": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_failures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "reason"],
        "properties": {
          "source": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "bucket", "verification_status", "sources", "signals", "related_terms", "why_it_matters", "meaning_zh", "user_intent_zh", "calligraphy_fit_zh", "fit_level", "suggested_chinese_text", "next_step_zh"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "bucket": {
            "enum": ["rising", "watch", "ignore"]
          },
          "verification_status": {
            "enum": ["confirmed", "search_led", "social_led", "weak"]
          },
          "sources": {
            "type": "array",
            "items": { "type": "string" }
          },
          "signals": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["source", "signal_type", "evidence"],
              "properties": {
                "source": { "type": "string" },
                "window": { "type": "string" },
                "signal_type": { "type": "string" },
                "growth": { "type": "string" },
                "evidence": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "related_terms": {
            "type": "array",
            "items": { "type": "string" }
          },
          "why_it_matters": { "type": "string" },
          "meaning_zh": { "type": "string" },
          "user_intent_zh": { "type": "string" },
          "calligraphy_fit_zh": { "type": "string" },
          "fit_level": {
            "enum": ["high", "medium", "low", "unknown"]
          },
          "suggested_chinese_text": {
            "type": "array",
            "items": { "type": "string" }
          },
          "next_step_zh": { "type": "string" },
          "risk_hint": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
